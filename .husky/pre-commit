#!/usr/bin/env sh
# Pre-commit: roda verificador de consistência visual quando o commit toca
# assets de imagens de ambientes ou os arquivos que mapeiam essas imagens.

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

TRIGGER=$(echo "$STAGED" | grep -E '^(src/assets/.+\.(jpe?g|png|webp)|src/lib/seo-rooms-data\.ts|src/lib/seo-landing-images\.ts|src/components/AmbientesGrid\.tsx)$' || true)

if [ -z "$TRIGGER" ]; then
  exit 0
fi

echo "🔍 Mudança em referências de imagens detectada. Rodando verificador visual..."
echo ""

if ! command -v bun >/dev/null 2>&1; then
  if [ -x "$HOME/.bun/bin/bun" ]; then
    export PATH="$HOME/.bun/bin:$PATH"
  else
    echo "⚠️  Bun não encontrado no PATH. Pulando verificador (degradado)."
    exit 0
  fi
fi

bun scripts/visual-consistency-check.ts --staged

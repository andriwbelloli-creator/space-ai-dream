# =============================================================
# Ideal Space (space-ai-dream) — variáveis de ambiente
#
# Como usar:
#   cp .env.example .env   (ou adicione as linhas que faltam ao
#   .env que já existe). Preencha as chaves reais.
#   O .env NUNCA é commitado — o .gitignore já cobre.
# =============================================================

# --- IA (já usado pelo space-ai-dream — src/lib/gemini.server.ts) ---
GOOGLE_AI_API_KEY="COLE_A_CHAVE_GEMINI_AQUI"

# --- Supabase — Fase 1 ---------------------------------------
# Projeto: amvydqpdqwubsrjjxxzt (o mesmo do Home Office Life —
# schema, tabelas e RLS já existem lá).
# Chaves em:
# https://supabase.com/dashboard/project/amvydqpdqwubsrjjxxzt/settings/api

# cliente (expostas no browser)
VITE_SUPABASE_URL="https://amvydqpdqwubsrjjxxzt.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="COLE_A_ANON_KEY_AQUI"
VITE_SUPABASE_PROJECT_ID="amvydqpdqwubsrjjxxzt"

# compat para server functions (mesmos valores acima)
SUPABASE_URL="https://amvydqpdqwubsrjjxxzt.supabase.co"
SUPABASE_PUBLISHABLE_KEY="COLE_A_ANON_KEY_AQUI"

# service role — SERVER-ONLY · SECRET · nunca exposto no client
SUPABASE_SERVICE_ROLE_KEY="COLE_A_SERVICE_ROLE_KEY_AQUI"

# --- Stripe (checkout + webhook) — SERVER-ONLY · nunca expor no client -----
# Em producao: configurar como Cloudflare Secrets (wrangler secret put).
# Em dev local: preencher no .env.local (nunca no .env commitado).
#
# Painel Stripe: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_COLE_AQUI"
STRIPE_PUBLISHABLE_KEY="pk_test_COLE_AQUI"
# "test" em dev, "live" em prod. Usado para validacao cruzada com a key acima.
STRIPE_MODE="test"
# Webhook secret gerado em: Stripe Dashboard > Webhooks > endpoint > Signing secret
# Para dev local com Stripe CLI: stripe listen --forward-to localhost:PORT/api/stripe-webhook
STRIPE_WEBHOOK_SECRET="whsec_COLE_AQUI"
# Price IDs do produto (Stripe Dashboard > Products > preco > ID)
STRIPE_PRICE_STARTER_MONTHLY="price_COLE_AQUI"
STRIPE_PRICE_STARTER_YEARLY="price_COLE_AQUI"
STRIPE_PRICE_PREMIUM_MONTHLY="price_COLE_AQUI"
STRIPE_PRICE_PREMIUM_YEARLY="price_COLE_AQUI"
STRIPE_PRICE_PRO_MONTHLY="price_COLE_AQUI"
STRIPE_PRICE_PRO_YEARLY="price_COLE_AQUI"

# --- Configurações do Browserless (QA Visual & Validação Funcional - Adicionar se disponível) ---
